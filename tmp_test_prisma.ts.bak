import prisma from "./lib/db/prisma";

async function main() {
    console.log("Prisma keys:", Object.keys(prisma).filter(k => !k.startsWith("_")));
    try {
        // @ts-ignore
        console.log("disasterZone exists:", typeof prisma.disasterZone !== "undefined");
    } catch (e) {
        console.log("Error accessing disasterZone:", e.message);
    }
}

main().catch(console.error);
